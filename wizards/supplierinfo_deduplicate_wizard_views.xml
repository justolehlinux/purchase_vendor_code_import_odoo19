<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="supplierinfo_deduplicate_wizard_form" model="ir.ui.view">
        <field name="name">supplierinfo.deduplicate.wizard.form</field>
        <field name="model">supplierinfo.deduplicate.wizard</field>
        <field name="arch" type="xml">
            <form string="Удалить точные дубликаты прайс-листа">
                <group>
                    <group>
                        <field name="selected_count"/>
                        <field name="duplicate_count"/>
                        <field name="conflict_count"/>
                    </group>
                </group>
                <field name="source_ids" invisible="1"/>
                <field name="summary" nolabel="1" readonly="1"/>
                <footer>
                    <button name="action_delete_exact_duplicates"
                            type="object"
                            string="Удалить точные дубликаты"
                            class="btn-primary"
                            confirm="Будут удалены только полностью одинаковые строки из выбранных записей. Продолжить?"/>
                    <button string="Отмена" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
